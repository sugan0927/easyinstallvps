{
  "name": "easyinstall-php-worker",
  "version": "1.0.0",
  "type": "module",
  "description": "EasyInstallPHP on Cloudflare Workers",
  "main": "src/index.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:prod": "wrangler deploy --env production",
    "deploy:dev": "wrangler deploy --env development",
    "logs": "wrangler tail",
    "build": "esbuild src/index.js --bundle --outfile=dist/index.js --platform=node --format=esm"
  },
  "dependencies": {
    "@php-wasm/node": "^0.1.0",
    "@php-wasm/web": "^0.1.0",
    "php-wasm": "^0.0.8"
  },
  "devDependencies": {
    "wrangler": "^4.73.0",
    "esbuild": "^0.20.0"
  },
  "keywords": ["php", "cloudflare", "workers", "installer"],
  "author": "sugan0927",
  "license": "MIT"
}
